---
import { getCollection } from 'astro:content';
import ArticleCard from '../../../components/ArticleCard.astro';
import Layout from '../../../layouts/Layout.astro';
import { articleMonth, articleYear, monthName, monthSlug } from '../../../lib/dates';
import { url } from '../../../lib/paths';
import { sortArticlesForDisplay } from '../../../lib/sortArticles';

export async function getStaticPaths() {
	const articles = await getCollection('articles', ({ data }) => !data.draft);
	const years = new Set(articles.map((a) => articleYear(a.data.date)));
	return Array.from(years).map((year) => ({ params: { year: String(year) } }));
}

const { year } = Astro.params;
const articles = sortArticlesForDisplay(
	(await getCollection('articles', ({ data }) => !data.draft)).filter(
		(a) => articleYear(a.data.date) === Number(year),
	),
);

const months = Array.from(new Set(articles.map((a) => articleMonth(a.data.date)))).sort((a, b) => b - a);
---

<Layout title={`${year} Archive`}>
	<div class="container">
		<header class="archive-header">
			<h1 class="archive-title">{year}</h1>
			<nav class="month-nav-inline" aria-label="Months in this year">
				{
					months.map((m) => (
						<a href={url(`/archive/${year}/${monthSlug(m)}/`)}>{monthName(m)}</a>
					))
				}
			</nav>
		</header>
		<ul class="article-list">
			{articles.map((article) => <ArticleCard article={article} />)}
		</ul>
	</div>
</Layout>
